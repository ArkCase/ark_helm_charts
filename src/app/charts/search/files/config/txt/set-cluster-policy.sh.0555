#!/bin/bash
set -euo pipefail
. /.functions

#
# Disable until tested
#
quit "Policy configuration is disabled"

generate_payload()
{
	local POLICY="${1}"
	echo -n '{ "set-cluster-policy": [ '"${NEW_POLICY}"' ] }'
}

set_or_default BASE_DIR "/app"
# set_or_default LOGS_DIR "${DATA_DIR}/logs"

# ensure_dir "${LOGS_DIR}"
# redirect_logs "${LOGS_DIR}/set-cluster-policy.log"

#
# Policies, top to bottom:
#
#	- Each shard cannot have more than one replica on the same node
#	- Each collection's replicas should be equally distributed amongst nodes
#	- All cores should be equally distributed amongst nodes
#
set_or_default SOLR_CLUSTER_POLICY '
{
	"replica": "<2",
	"shard": "#EACH",
	"node": "#ANY",
	"strict" true
},
{
	"replica": "#EQUAL",
	"node": "#ANY",
	"strict": true
},
{
	"cores": "#EQUAL",
	"node": "#ANY",
	"strict": true
}
'

set_or_default AUTOSCALING_API "solr/admin/autoscaling"

URL="https://localhost:8983/${AUTOSCALING_API}"

[ "${SOLR_CLUSTER_POLICY:-"-"}" == "-" ] && quit "No cluster policy to be set"

# if the policy starts with "@", assume it's pointing to a file
if [[ "${SOLR_CLUSTER_POLICY}" =~ ^@(.*)$ ]] ; then
	# It's a file, so load it from the file!
	POLICY_FILE="${BASH_REMATCH[1]}"
	eyes "Loading the cluster policy from the file [${POLICY_FILE}]..."
	require_file_readable "${POLICY_FILE}"
	SOLR_CLUSTER_POLICY="$(<"${POLICY_FILE}")" || fail "Failed to load the cluster policy from the file [${POLICY_FILE}]"
fi

NEW_POLICY="$(jq -r <<< "${SOLR_CLUSTER_POLICY}")" || fail "The cluster policy is not valid JSON (rc=${?}): ${NEW_POLICY}\n\n${SOLR_CLUSTER_POLICY}"

OLD_POLICY="$(curl -fsSL "${URL}" 2>&1)" || fail "Failed to query the old policy - can't proceed with installing the new one!"

#
# TODO: Compare the old policy to the new one
#

eyes "Applying the cluster policy:\n${NEW_POLICY}"

export NEW_POLICY

OUT="$(curl -fsSL -X POST -H "Content-type:application/json" -d "$(generate_payload "${NEW_POLICY}")" "${URL}" 2>&1)" || fail "Failed to apply the cluster policy (rc=${?}): ${OUT}"
ok "Cluster policy applied!"
