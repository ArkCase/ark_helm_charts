#!/bin/bash
set -euo pipefail
. /.functions

# This causes us to wait until the SSL stuff is initialized
# since apparently the flock in the main script is ineffective
export ACME_WAIT="true"
init_ssl

cleanup()
{
	[ -v RUN_MARKER ] && rm -rf "${RUN_MARKER}" &>/dev/null
}

RUN_MARKER="${HOME_DIR}/.initRan"
trap cleanup EXIT

set_or_default BASE_DIR "/app"
set_or_default INIT_DIR "${BASE_DIR}/init"
set_or_default DATA_DIR "${BASE_DIR}/data"
set_or_default LOGS_DIR "${DATA_DIR}/logs"

ensure_dir "${LOGS_DIR}"
redirect_logs "${LOGS_DIR}/config-post.log"

# How long to sleep between polling attempts
set_or_default INIT_POLL_SLEEP "1s"
INIT_POLL_SLEEP_STR="$(secs_to_timestr "${INIT_POLL_SLEEP}")" || fail "Invalid timestring [${INIT_POLL_SLEEP}]"
INIT_POLL_SLEEP_SEC="$(timestr_to_secs "${INIT_POLL_SLEEP_STR}")"

# By default, wait up to 90 seconds if not told otherwise
set_or_default INIT_MAX_WAIT "90s"
INIT_MAX_WAIT_STR="$(secs_to_timestr "${INIT_MAX_WAIT}")" || fail "Invalid timestring [${INIT_MAX_WAIT}]"
INIT_MAX_WAIT_SEC="$(timestr_to_secs "${INIT_MAX_WAIT_STR}")"

set_or_default POLL_PATH "/solr/admin/info/health"

#
# We poll localhost vs. the service b/c the service won't route
# traffic until the pod is ready, whereas the local instance may
# already be ready to help us with our initializations.
#
export POLL_URL="https://localhost:8983${POLL_PATH}"

FIRST="true"
START="$(date +%s)"
while true ; do
	RC=0
	OUT="$(curl -m 5 -fsSL --config <(auth_params "${SOLR_ADMIN_USERNAME}" "${SOLR_ADMIN_PASSWORD}") "${POLL_URL}" 2>&1)" || RC=${?}
	[ ${RC} -eq 0 ] && break

	as_boolean "${FIRST}" && sleeping "Waiting for Solr at [${POLL_URL}] (up to ${INIT_MAX_WAIT_STR})..."
	FIRST="false"

	[ $(( $(date +%s) - START )) -ge ${INIT_MAX_WAIT_SEC} ] && fail "Timed out waiting for Solr at [${POLL_URL}] (rc=${RC}): ${OUT}"
	sleep "${INIT_POLL_SLEEP_SEC}" || fail "Polling cycle sleep interrupted"
done
ok "Solr is ready"

# Don't run if init didn't run
is_file "${RUN_MARKER}" || exit 0

# Run the scripts due to be run before Solr is booted up
INIT_DIR="${INIT_DIR}/post"
doing "Initializing from the post-initialization scripts in [${INIT_DIR}]..."
if is_dir_readable "${INIT_DIR}" ; then
	cd "${INIT_DIR}" || fail "Failed to CD into [${INIT_DIR}]"
	(
		set -euo pipefail
		while read script ; do
			is_file_executable "${script}" || continue
			# Run the script
			say "\tInitializing from script [${script}]..."
			"${script}" 2>&1 || exit 1
		done < <(/usr/bin/find . -mindepth 1 -maxdepth 1 -type f -name '*.sh' | sort)
	) || fail "Initialization failed"
fi
ok "Initialization complete"
exit 0
